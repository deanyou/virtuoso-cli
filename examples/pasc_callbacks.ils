;;;============================================================================
printf("\n")
printf("======================================================================\n")
printf("  Spectre Simulation Callback Handler Loaded\n")
printf("  Topic: pascDone errors from callbacks\n")
printf("======================================================================\n")
printf("\nAvailable procedures:\n")
printf("\n  Core Callbacks (normally called by Spectre):\n")
printf("    pascDoneCB(session resultsDir @key errorList)\n")
printf("    pascErrorCB(session errorMsg @key errorCode)\n")
printf("    pascStartCB(session params)\n")
printf("    pascAbortCB(session reason)\n")
printf("    pascProgressCB(session progressInfo)\n")
printf("\n  Registration:\n")
printf("    registerSimulationCallbacks(session)  - Register all callbacks\n")
printf("    unregisterSimulationCallbacks(session) - Cleanup callbacks\n")
printf("    safeSimulationRun(@key design analysis) - Run with callbacks\n")
printf("\n  Debugging:\n")
